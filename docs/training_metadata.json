{
  "script": "AITrainer_distilbert_2.py",
  "version_note": "Modelo entrenado previamente y publicado en Hugging Face para inferencia en este MVP.",
  "base_model": "distilbert-base-uncased",
  "freeze_policy": "Descongelada la ultima capa del transformer (layer.5).",
  "classifier_head": {
    "dropout_1": 0.3,
    "dense_units": 256,
    "activation": "ReLU",
    "dropout_2": 0.2,
    "output_units": 2
  },
  "dataset": "balanced_dataset_generated.csv",
  "split": {
    "train": 0.9,
    "validation": 0.1,
    "random_state": 42
  },
  "hyperparameters": {
    "epochs": 4,
    "batch_size": 768,
    "learning_rate": 2e-5,
    "max_length": 64,
    "weight_decay": 0.01,
    "optimizer": "AdamW",
    "scheduler": "linear",
    "warmup_ratio": 0.1
  },
  "task": "binary_classification",
  "labels": {
    "0": "Seguro",
    "1": "Sospechoso"
  }
}
